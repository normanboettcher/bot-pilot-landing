<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <artifactId>bot-pilot-crypto</artifactId>
    <groupId>de.bot.pilot.crypto</groupId>
    <version>0.0.1-SNAPSHOT</version>
    <name>bot-pilot :: crypto</name>
    <packaging>pom</packaging>
    <url/>
    <licenses>
        <license/>
    </licenses>
    <developers>
        <developer>
            <name>Norman-Ian Böttcher</name>
            <email>norman.boettcher@web.de</email>
        </developer>
    </developers>
    <scm>
        <connection/>
        <developerConnection/>
        <tag/>
        <url/>
    </scm>
    <properties>
        <java.version>25</java.version>
        <org.springframework.boot.version>4.0.1</org.springframework.boot.version>
        <org.springframework.cloud.version>2025.1.0</org.springframework.cloud.version>
        <org.springframework.vault.version>4.0.0</org.springframework.vault.version>
        <org.slf4j.version>2.0.16</org.slf4j.version>
        <de.bot.pilot.crypto.bom.version>1.0.0-SNAPSHOT
        </de.bot.pilot.crypto.bom.version>

        <maven.compiler.release>25</maven.compiler.release>
        <!--  Enable preview features (structured concurrency, etc.)  -->
        <maven.compiler.enablePreview>true</maven.compiler.enablePreview>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!--  mvnd: max threads = CPU cores — tune per machine  -->
        <maven.build.timestamp.format>yyyy-MM-dd HH:mm</maven.build.timestamp.format>

    </properties>
    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>de.bot.pilot.crypto</groupId>
                <artifactId>bot-pilot-crypto-bom</artifactId>
                <version>${de.bot.pilot.crypto.bom.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${org.springframework.boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>org.springframework.vault</groupId>
                <artifactId>spring-vault-core</artifactId>
                <version>${org.springframework.vault.version}</version>
            </dependency>
            <dependency>
                <groupId>io.github.resilience4j</groupId>
                <artifactId>resilience4j-spring-boot3</artifactId>
                <version>2.2.0</version>
            </dependency>
            <dependency>
                <groupId>io.github.resilience4j</groupId>
                <artifactId>resilience4j-retry</artifactId>
                <version>2.2.0</version>
            </dependency>
            <dependency>
                <groupId>io.github.resilience4j</groupId>
                <artifactId>resilience4j-circuitbreaker</artifactId>
                <version>2.2.0</version>
            </dependency>
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>slf4j-api</artifactId>
                <version>${org.slf4j.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>
    <!--  ── Global build settings ──────────────────────────────────────────  -->

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>3.13.0</version>
                    <configuration>
                        <release>25</release>
                        <compilerArgs>
                            <arg>--enable-preview</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>3.5.2</version>
                    <configuration>
                        <!--  Each module runs its own tests in parallel during build  -->
                        <forkCount>1</forkCount>
                        <reuseForks>true</reuseForks>
                        <argLine>--enable-preview</argLine>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-maven-plugin</artifactId>
                    <version>4.0.1</version>
                    <configuration>
                        <skip>true</skip>
                        <!--  only app-bootstrap overrides this to false  -->
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

    <modules>
        <module>bot-pilot-crypto-api</module>
        <module>bot-pilot-crypto-application</module>
        <module>bot-pilot-crypto-infrastructure</module>
        <module>bot-pilot-crypto-domain</module>
    </modules>
</project>
