<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="001-create-contact-form-customer" author="norman-ian.boettcher">
        <createTable tableName="contact_form_customer">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(255)"/>
            <column name="last_name" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="company" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="001-create-email-request" author="norman-ian.boettcher">
        <createTable tableName="email_request">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="content" type="TEXT"/>
            <column name="subject" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="success" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="contact_form_customer_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_email_request_customer"
                             references="contact_form_customer(id)"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
